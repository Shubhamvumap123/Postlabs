# 🚨 SECURITY WARNING 🚨
# These variables are for documentation purposes only.
# Do NOT store real API keys or secrets in this file or commit them to version control.
# In production, these should be managed by your deployment platform's secrets manager.

# Mailchimp Configuration
# NOTE: Using these keys directly in client-side code (VITE_*) exposes them to the public.
# A secure implementation should use a backend proxy to handle API requests.
VITE_MAILCHIMP_API_KEY=your_mailchimp_api_key_here
VITE_MAILCHIMP_SERVER_PREFIX=us1
VITE_MAILCHIMP_LIST_ID=your_list_id_here

# API URL (for backend proxy)
VITE_API_URL=http://localhost:3000/api
